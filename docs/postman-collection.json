  "item": [
    {
      "name": "Auth",
      "description": "浏览器授权和 token 换取相关接口",
      "item": [
        {
          "name": "Authorize Page",
          "request": {
            "method": "GET",
            "description": "浏览器回调登录时打开的授权页入口",
            "url": {
              "raw": "{{authBaseUrl}}/oauth/authorize?response_type=code&client_id={{clientId}}&redirect_uri={{redirectUri}}&scope={{scope}}&code_challenge={{codeChallenge}}&code_challenge_method=S256&id_token_add_organizations=true&codex_cli_simplified_flow=true&state={{state}}&originator=Codex%20Desktop",
              "host": [
                "{{authBaseUrl}}"
              ],
              "path": [
                "oauth",
                "authorize"
              ],
              "query": [
                {
                  "key": "response_type",
                  "value": "code"
                },
                {
                  "key": "client_id",
                  "value": "{{clientId}}"
                },
                {
                  "key": "redirect_uri",
                  "value": "{{redirectUri}}"
                },
                {
                  "key": "scope",
                  "value": "{{scope}}"
                },
                {
                  "key": "code_challenge",
                  "value": "{{codeChallenge}}"
                },
                {
                  "key": "code_challenge_method",
                  "value": "S256"
                },
                {
                  "key": "id_token_add_organizations",
                  "value": "true"
                },
                {
                  "key": "codex_cli_simplified_flow",
                  "value": "true"
                },
                {
                  "key": "state",
                  "value": "{{state}}"
                },
                {
                  "key": "originator",
                  "value": "Codex Desktop"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Exchange Authorization Code",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "description": "浏览器登录或设备码登录最终使用授权码换取 token",
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "grant_type",
                  "value": "authorization_code",
                  "type": "text"
                },
                {
                  "key": "code",
                  "value": "{{authorizationCode}}",
                  "type": "text"
                },
                {
                  "key": "redirect_uri",
                  "value": "{{redirectUri}}",
                  "type": "text"
                },
                {
                  "key": "client_id",
                  "value": "{{clientId}}",
                  "type": "text"
                },
                {
                  "key": "code_verifier",
                  "value": "{{codeVerifier}}",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{authBaseUrl}}/oauth/token",
              "host": [
                "{{authBaseUrl}}"
              ],
              "path": [
                "oauth",
                "token"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "description": "已保存账号使用 refresh_token 刷新 token",
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "grant_type",
                  "value": "refresh_token",
                  "type": "text"
                },
                {
                  "key": "refresh_token",
                  "value": "{{refreshToken}}",
                  "type": "text"
                },
                {
                  "key": "client_id",
                  "value": "{{clientId}}",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{authBaseUrl}}/oauth/token",
              "host": [
                "{{authBaseUrl}}"
              ],
              "path": [
                "oauth",
                "token"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Device Auth",
      "description": "设备码登录流程相关接口",
      "item": [
        {
          "name": "Request Device Code",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "description": "申请 device_auth_id 和 user_code",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"client_id\": \"{{clientId}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{authBaseUrl}}/api/accounts/deviceauth/usercode",
              "host": [
                "{{authBaseUrl}}"
              ],
              "path": [
                "api",
                "accounts",
                "deviceauth",
                "usercode"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Poll Device Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "description": "轮询设备码授权状态，成功后返回 authorization_code 和 code_verifier",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"device_auth_id\": \"{{deviceAuthId}}\",\n  \"user_code\": \"{{userCode}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{authBaseUrl}}/api/accounts/deviceauth/token",
              "host": [
                "{{authBaseUrl}}"
              ],
              "path": [
                "api",
                "accounts",
                "deviceauth",
                "token"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Open Device Verification Page",
          "request": {
            "method": "GET",
            "description": "在浏览器打开该页面，输入 user_code 完成授权",
            "url": {
              "raw": "{{authBaseUrl}}/codex/device",
              "host": [
                "{{authBaseUrl}}"
              ],
              "path": [
                "codex",
                "device"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
