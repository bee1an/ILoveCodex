{
  "name": "codexdock",
  "version": "0.4.2",
  "description": "CodexDock desktop account manager for Codex sessions",
  "main": "./out/main/index.js",
  "author": "bee1an",
  "homepage": "https://github.com/bee1an/CodexDock",
  "repository": {
    "type": "git",
    "url": "https://github.com/bee1an/CodexDock.git"
  },
  "scripts": {
    "format": "prettier --plugin prettier-plugin-svelte --write .",
    "lint": "eslint --cache .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:cli": "tsc --noEmit -p tsconfig.cli.json",
    "svelte-check": "svelte-check --tsconfig ./tsconfig.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:cli && npm run svelte-check",
    "build:cli": "tsc -p tsconfig.cli.json",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "cdock": "npm run build:cli && electron ./out/cli/cli/index.js",
    "build": "npm run typecheck && npm run build:cli && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@iarna/toml": "^2.2.5",
    "chart.js": "^4.5.1",
    "electron-updater": "^6.3.9",
    "gsap": "^3.15.0",
    "ms": "^2.1.3"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@iconify-json/lucide": "^1.2.96",
    "@sveltejs/vite-plugin-svelte": "^6.2.0",
    "@testing-library/svelte": "^5.3.1",
    "@types/node": "^22.19.1",
    "@unocss/extractor-svelte": "^66.6.6",
    "@unocss/preset-icons": "^66.6.6",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-svelte": "^3.13.1",
    "jsdom": "^29.0.2",
    "prettier": "^3.7.4",
    "prettier-plugin-svelte": "^3.4.0",
    "svelte": "^5.45.6",
    "svelte-check": "^4.3.4",
    "svelte-dnd-action": "^0.9.69",
    "typescript": "^5.9.3",
    "unocss": "^66.6.6",
    "vite": "^7.2.6",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
